{
  "name": "controle-contas",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Controle de Contas/Faturas",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
